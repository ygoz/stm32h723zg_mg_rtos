      {"title": "BIT", "icon": "link", "css": "padding: 0.75rem;\ngap: 0.5rem;\nmin-height: 2rem;\ndisplay: flex;\nflex-direction: column;\nflex-grow: 1;", "layout": [
          {"classes": "container", "css": "flex-direction: column;\nheight: 11.5rem;\ngap: 0.5rem;\nflex-wrap: wrap;", "layout": [
