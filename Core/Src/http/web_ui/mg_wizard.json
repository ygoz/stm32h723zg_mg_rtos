                ]},
              {"classes": "card", "layout": [
                  {"format": "Firmware version"},
                  {"format": "${state.version}"}
                ]}
            ]},
          {"classes": "container", "css": "gap: 0.5rem;", "layout": [
              {"classes": "container", "css": "flex-direction: column; gap: 0.5rem; flex: 0 0 auto; width: 16rem;", "layout": [
                  {"classes": "panel", "layout": [
                      {"classes": "title", "format": "LED control panel"},
                      {"classes": "labeled", "layout": [
                          {"classes": "label", "format": "Red"},
                          {"type": "toggle", "ref": "leds.red", "autosave": true}
                        ]},
                      {"classes": "labeled", "layout": [
                          {"classes": "label", "format": "Green"},
                          {"type": "toggle", "ref": "leds.green", "autosave": true, "css": "background-color: #22c55e !important;"}
                        ]},
                      {"classes": "labeled", "layout": [
                          {"classes": "label", "format": "Blue"},
                          {"type": "toggle", "ref": "leds.blue", "autosave": true, "css": "height: 1.600000023841858rem;"}
                        ]}
                    ]},
                  {"classes": "panel", "layout": [
                      {"classes": "title", "format": "Status panel"},
                      {"classes": "labeled", "layout": [
                          {"classes": "label", "format": "Online status"},
                          {"type": "icon", "icon": "circle", "css": "${state.online ? \"color:var(--drawColor);\" : \"color:var(--bgColor);\"}"}
                        ]},
                      {"classes": "labeled", "layout": [
                          {"classes": "label", "format": "Console status"},
                          {"type": "icon", "icon": "circle", "css": "${state.lights ? \"color:var(--drawColor);\" : \"color:var(--bgColor);\"}"}
                        ]}
                    ]},
                  {"type": "container", "classes": "container", "css": "flex-direction: column;\ngap: 0.5rem;", "layout": [
                      {"classes": "panel", "css": "flex: 0 0 auto;\nflex-basis: 0 0 auto;\nwidth: 16rem;", "layout": [
                          {"classes": "container", "css": "gap: 0.5rem;", "layout": [
                              {"css": "white-space: nowrap;\ntext-overflow: ellipsis;\nfont-weight: 700;", "format": "Heap Memory"}
                            ]},
                          {"css": "display: flex;\nalign-items: center;\njustify-content: space-between;\ngap: 1rem;", "layout": [
                              {"format": "Total Heap"},
                              {"type": "input", "ref": "state.total_heap_memory", "css": "flex: 0 0 auto;\nwidth: 8rem;"}
                            ]},
                          {"css": "display: flex;\nalign-items: center;\njustify-content: space-between;\ngap: 1rem;", "layout": [
                              {"format": "Free Heap"},
                              {"type": "input", "ref": "state.free_heap_memory", "css": "flex: 0 0 auto;\nwidth: 8rem;"}
                            ]},
                          {"css": "margin-top: 0.25rem; justify-content:end;display:flex; align-items:center; gap: 1rem;", "layout": [
                              {"type": "progress", "ref": "state.used_heap_memory"}
                            ]}
                        ]}
                    ]}
                ]},
              {"classes": "container", "css": "flex-direction: column;\ngap: 0.5rem;", "layout": [
                  {"classes": "container", "css": "gap:0.5rem;", "layout": [
                      {"classes": "panel", "css": "flex-grow: 1;", "layout": [
                          {"format": "Temperature", "classes": "title"},
                          {"type": "graph", "ref": "websocket.temperature", "css": "flex-grow: 1;\nheight: 7.5rem;", "options": {"xrange": 60}}
                        ]}
                    ]},
                  {"classes": "container", "layout": [
                      {"classes": "panel", "layout": [
                          {"classes": "title", "format": "Developer note"},
                          {"format": "To add/remove/rename pages, select the \"sidebar\" tab at the bottom and adjust the configuration."},
                          {"format": "To edit the contents of a page, click on elements and edit/add/delete them as required. To adjust the settings of an element, select it and edit properties it in the bottom toolbox."},
                          {"format": "To attach UI control to your device, add REST API endpoint first, then select a control and set the 'API variable' to that endpoint."},
                          {"format": "To edit the configuration manually, click on the \"export\" button to download wizard.json configuration file. Edit it, and import back."},
                          {"format": "Click on the \"Docs\" toolbar button to view the JSON format details."}
                        ], "css": "height: 14rem;"}
                    ]}
                ]}
            ]}
        ]},
      {"title": "Device Settings", "icon": "settings", "level": "7", "classes": "page", "layout": [
