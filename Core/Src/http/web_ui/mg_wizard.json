                    ]},
                  {"classes": "panel", "css": "flex: 0 0 auto;\nwidth: 7rem;\nheight: 9.25rem;\nflex-basis: 0 0 auto;\ntext-align: center;", "layout": [
                      {"classes": "container", "css": "gap: 0.5rem;", "layout": [
