{
  "version": "1.0.2", 
  "http": {"http": true, "https": false, "ui": true, "login": true}, 
  "mqtt": {"enable": false, "url": "mqtt://broker.hivemq.com:1883"}, 
  "websocket": {"enable": true}, 
  "dns": {"type": "default", "url": "udp://8.8.8.8:53", "captive": false, "mdns": true, "localname": "fuck_bitches_get_money"}, 
  "sntp": {"enable": false, "type": 0, "url": "udp://time.google.com:123", "interval": 3600}, 
  "modbus": {"enable": false, "port": 502}, 
  "build": {"mode": "new", "board": "h723", "ide": "GCC+make", "rtos": "FreeRTOS"}, 
  "api": {
    "hil": {
      "type": "data", 
      "read_level": 0, 
      "write_level": 0, 
      "attributes": {
        "master": {"type": "bool", "value": true}, 
        "i2c1": {"type": "bool", "value": false}, 
        "i2c4": {"type": "bool", "value": false}, 
        "spi4": {"type": "bool", "value": false}, 
        "spi5": {"type": "bool", "value": false}, 
        "uart8": {"type": "bool", "value": false}, 
        "uart10": {"type": "bool", "value": false}
      }, 
      "readonly": true
    }, 
    "reboot": {
      "type": "action", 
      "read_level": 3, 
      "write_level": 7
    }, 
    "reformat": {
      "type": "action", 
      "read_level": 3, 
      "write_level": 7
    }, 
    "firmware_update": {
      "type": "ota", 
      "read_level": 3, 
      "write_level": 7
    }, 
    "file_upload": {
      "type": "upload", 
      "read_level": 3, 
      "write_level": 7, 
      "readonly": false
    }, 
    "state": {
      "type": "data", 
      "readonly": true, 
      "attributes": {
        "used_heap_memory": {"type": "int", "value": 42}, 
        "total_heap_memory": {"type": "int", "value": 42}, 
        "free_heap_memory": {"type": "int", "value": 42}, 
        "version": {"type": "string", "value": "1.0.0", "size": 20}, 
        "online": {"type": "bool", "value": true}, 
        "lights": {"type": "bool", "value": true}
      }
    }, 
    "leds": {
      "type": "data", 
      "read_level": 3, 
      "write_level": 3, 
      "attributes": {
        "red": {"type": "bool", "value": false}, 
        "green": {"type": "bool", "value": true}, 
        "blue": {"type": "bool", "value": false}
      }
    }, 
    "network_settings": {
      "type": "data", 
      "read_level": 3, 
      "write_level": 7, 
      "attributes": {
        "ip_address": {"type": "string", "value": "192.168.1.10", "size": 20}, 
        "gw_address": {"type": "string", "value": "192.168.1.254", "size": 20}, 
        "netmask": {"type": "string", "value": "255.255.255.0", "size": 20}, 
        "dhcp": {"type": "bool", "value": false}
      }
    }, 
    "settings": {
      "type": "data", 
      "read_level": 3, 
      "write_level": 7, 
      "attributes": {
        "string_val": {"type": "string", "value": "edit & save me", "size": 40}, 
        "log_level": {"type": "string", "size": 10, "value": "info"}, 
        "double_val": {"type": "double", "value": 123.12345, "format": "%.5f"}, 
        "int_val": {"type": "int", "value": 17}, 
        "bool_val": {"type": "bool", "value": true}
      }
    }, 
    "login": {"type": "local", "attributes": {"username": {"type": "string", "value": "", "size": 20}, "password": {"type": "string", "value": "", "size": 20}}}, 
    "local": {
      "type": "local", 
      "attributes": {
        "username": {"type": "string", "value": "Joe", "size": 50}, 
        "lastsync": {"type": "string", "value": "", "size": 50}, 
        "online": {"type": "bool", "value": false}, 
        "userlevel": {"type": "int", "value": 7}
      }
    }, 
    "websocket": {"type": "websocket", "readonly": true, "attributes": {"voltage": {"type": "int", "value": 42}, "temperature": {"type": "int", "value": 42}}}, 
    "save_event": {
      "type": "action"
    }, 
    "events": {
      "type": "custom", 
      "value": [
        {
          "id": 0, 
          "timestamp": 12345, 
          "message": "Something failed", 
          "priority": 2, 
          "status": "active", 
          "notes": "some notes"
        },
        {
          "id": 1, 
          "timestamp": 12395, 
          "message": "Something succeeded", 
          "priority": 1, 
          "status": "processed", 
          "notes": ""
        }
      ]
    }
  }, 
  "ui": {
    "production": false, 
    "brand": "My Brand", 
    "logo": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<svg viewBox=\"0 0 600 150\" xmlns=\"http://www.w3.org/2000/svg\">\n  <rect x=\"0\" y=\"0\" width=\"600\" height=\"150\" rx=\"20\" ry=\"20\" style=\"stroke: none; fill: #e1e5e9;\"/>\n  <text style=\"fill: #94A3B8; font-family: Arial, sans-serif; font-size: 92px;dominant-baseline: middle; text-anchor: middle; \" x=\"50%\" y=\"50%\">my logo</text>\n</svg>", 
    "toolbar": {"label": "My product console", "css": "flex-grow: 1;", "layout": [
        {"classes": "container", "css": "flex-grow: 1;\njustify-content: center;", "layout": [
            {"classes": "container", "css": "align-items: center;", "layout": [
                {"type": "image", "image": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<svg viewBox=\"0 0 600 150\" xmlns=\"http://www.w3.org/2000/svg\">\n  <rect x=\"0\" y=\"0\" width=\"600\" height=\"150\" rx=\"20\" ry=\"20\" style=\"stroke: none; fill: #e1e5e9;\"/>\n  <text style=\"fill: #94A3B8; font-family: Arial, sans-serif; font-size: 92px;dominant-baseline: middle; text-anchor: middle; \" x=\"50%\" y=\"50%\">my logo</text>\n</svg>", "css": "width: 8.5rem; height: 1.5rem; align-items: center; justify-content: center; display: flex;"}
              ]},
            {"classes": "container", "css": "margin-left: auto; align-items: center", "layout": [
                {"type": "icon", "icon": "circle", "css": "flex: 0 0 auto;\nheight: 1rem;\nwidth: 1rem;\n${local.online ? \"color:var(--drawColor);\" : \"color:var(--bgColor);\"}"},
                {"type": "text", "format": "last sync: ${local.lastsync}", "css": "margin: 0 0 0 0.5rem;", "classes": "${local.heartbeat.status ? 'hidden' : ''}"},
                {"type": "text", "format": "|", "css": "margin:0 0.5rem;"},
                {"type": "text", "format": "HaGeneral Console"},
                {"type": "text", "format": "|", "css": "margin:0 0.5rem;"},
                {"type": "text", "format": "${local.username}"},
                {"type": "icon", "icon": "user", "css": "margin: 0 0.5rem"},
                {"type": "logoutbutton", "icon": "sign-out"}
              ]}
          ]}
      ]}, 
    "heartbeat": 1, 
    "theme": {
    }, 
    "classes": "", 
    "pages": [
      {"title": "Dashboard", "icon": "desktop", "level": 0, "classes": "page", "layout": [
          {"classes": "container", "css": "flex-wrap: wrap;\ngap: 0.5rem;", "layout": [
              {"classes": "card", "layout": [
